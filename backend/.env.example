NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://philix:philix_secret@localhost:5432/philix_finance?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP Email (Gmail or Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Philix Finance <noreply@philixfinance.com>"

# AWS S3 Compatible Storage (use MinIO locally)
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=philix-documents
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Company
COMPANY_NAME="Philix Finance"
COMPANY_SLOGAN="Creating a Future Together"
COMPANY_PHONE="+260 XXX XXXXXX"
COMPANY_EMAIL=info@philixfinance.com
COMPANY_ADDRESS="Lusaka, Zambia"

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# MFA
MFA_ISSUER="Philix Finance"
