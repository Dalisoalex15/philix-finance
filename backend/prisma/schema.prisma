// Philix Finance - Complete Prisma Schema
// Production-grade schema for Zambian Microfinance Institution

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  MANAGER
  LOAN_OFFICER
  COLLECTIONS_OFFICER
  ACCOUNTANT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum ClientType {
  STUDENT
  CIVIL_SERVANT
  BUSINESS_OWNER
  MARKET_TRADER
  ENTREPRENEUR
}

enum ClientStatus {
  ACTIVE
  BLACKLISTED
  DECEASED
  INACTIVE
}

enum RiskRating {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LoanStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  OVERDUE
  DEFAULTED
  PAID
  REJECTED
  CANCELLED
  RESTRUCTURED
}

enum RepaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  WAIVED
}

enum CollateralStatus {
  HELD
  RELEASED
  AUCTIONED
  LOST
  DAMAGED
  UNDER_REVIEW
}

enum CollateralType {
  SMARTPHONE
  LAPTOP
  TABLET
  GAMING_CONSOLE
  TELEVISION
  CAMERA
  SMART_WATCH
  POWER_TOOL
  GENERATOR
  OTHER_ELECTRONICS
  OTHER
}

enum CollateralCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum DocumentType {
  NRC_FRONT
  NRC_BACK
  PASSPORT_PHOTO
  PROOF_OF_RESIDENCE
  STUDENT_CARD
  BUSINESS_LICENSE
  EMPLOYMENT_LETTER
  PAYSLIP
  BANK_STATEMENT
  COLLATERAL_PHOTO_FRONT
  COLLATERAL_PHOTO_BACK
  COLLATERAL_PHOTO_SIDE
  COLLATERAL_SERIAL
  LOAN_AGREEMENT
  COLLATERAL_RECEIPT
  PAYMENT_RECEIPT
  CLEARANCE_LETTER
  EXPENSE_RECEIPT
  OTHER
}

enum NotificationType {
  PAYMENT_REMINDER
  PAYMENT_OVERDUE
  LOAN_APPROVED
  LOAN_REJECTED
  LOAN_DISBURSED
  LOAN_CLOSED
  COLLATERAL_RELEASED
  TASK_ASSIGNED
  ANNOUNCEMENT
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ExpenseCategory {
  SALARY
  RENT
  UTILITIES
  INTERNET
  AIRTIME
  FUEL
  TRANSPORT
  MARKETING
  STATIONERY
  MAINTENANCE
  INSURANCE
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum CollectionStatus {
  CURRENT
  AT_RISK
  DAYS_30
  DAYS_60
  DAYS_90
  DEFAULT
}

enum InvestorStatus {
  ACTIVE
  EXITED
  SUSPENDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  DISBURSE
  PAYMENT
  RELEASE_COLLATERAL
  REPOSSESS
  EXPORT
  VIEW_SENSITIVE
}

enum RecoveryStatus {
  REPOSSESSED
  LISTED_FOR_AUCTION
  AUCTIONED
  RECOVERED_PARTIAL
  RECOVERED_FULL
  WRITTEN_OFF
}

// ============================================================
// BRANCHES
// ============================================================

model Branch {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  address     String
  city        String
  phone       String?
  email       String?
  managerId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  clients     Client[]
  loans       Loan[]
  expenses    Expense[]
}

// ============================================================
// USERS
// ============================================================

model User {
  id               String     @id @default(uuid())
  employeeId       String     @unique
  firstName        String
  lastName         String
  email            String     @unique
  phone            String
  passwordHash     String
  role             UserRole
  status           UserStatus @default(ACTIVE)
  branchId         String?
  branch           Branch?    @relation(fields: [branchId], references: [id])
  avatarUrl        String?
  mfaEnabled       Boolean    @default(false)
  mfaSecret        String?
  lastLoginAt      DateTime?
  lastLoginIp      String?
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  refreshTokens    RefreshToken[]
  sessions         UserSession[]
  loansCreated     Loan[]         @relation("LoanOfficer")
  loansApproved    Loan[]         @relation("LoanApprover")
  payments         Payment[]      @relation("PaymentRecorder")
  tasksAssigned    Task[]         @relation("TaskAssignee")
  tasksCreated     Task[]         @relation("TaskCreator")
  auditLogs        AuditLog[]
  notifications    Notification[]
  collectionLogs   CollectionLog[]
  announcements    Announcement[]
  expenses         Expense[]
  wikiPages        WikiPage[]
  communicationLogs CommunicationLog[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
}

model UserSession {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String   @unique
  ipAddress  String
  userAgent  String
  device     String?
  location   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
}

// ============================================================
// CLIENTS (CRM)
// ============================================================

model Client {
  id              String       @id @default(uuid())
  clientNumber    String       @unique
  type            ClientType
  status          ClientStatus @default(ACTIVE)
  riskRating      RiskRating   @default(MEDIUM)
  branchId        String?
  branch          Branch?      @relation(fields: [branchId], references: [id])
  loanOfficerId   String?

  // Personal Information
  firstName       String
  lastName        String
  middleName      String?
  nrcNumber       String       @unique
  dateOfBirth     DateTime
  gender          String
  phone           String
  whatsapp        String?
  email           String?
  address         String
  city            String
  province        String?

  // Student Information
  studentId       String?
  university      String?
  course          String?
  yearOfStudy     Int?

  // Employment Information
  employer        String?
  jobTitle        String?
  monthlySalary   Float?
  payDate         Int?
  employmentStartDate DateTime?

  // Business Information
  businessName    String?
  businessType    String?
  marketLocation  String?
  monthlyRevenue  Float?
  yearsOperating  Int?

  // Internal Scoring
  internalScore   Float        @default(50)
  previousLoans   Int          @default(0)
  defaultCount    Int          @default(0)
  reliabilityScore Float       @default(50)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  loans           Loan[]
  collaterals     Collateral[]
  documents       Document[]
  communicationLogs CommunicationLog[]
  followUps       FollowUp[]
  riskScoreHistory RiskScoreHistory[]
}

model CommunicationLog {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // CALL, EMAIL, MEETING, NOTE, WHATSAPP
  subject     String?
  notes       String
  outcome     String?
  nextAction  String?
  createdAt   DateTime @default(now())
}

model FollowUp {
  id          String    @id @default(uuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  dueDate     DateTime
  type        String
  notes       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdById String
  createdAt   DateTime  @default(now())
}

model RiskScoreHistory {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  score       Float
  rating      RiskRating
  reason      String?
  createdAt   DateTime @default(now())
  createdById String?
}

// ============================================================
// COLLATERAL VAULT
// ============================================================

model Collateral {
  id              String             @id @default(uuid())
  vaultId         String             @unique
  clientId        String
  client          Client             @relation(fields: [clientId], references: [id])
  type            CollateralType
  status          CollateralStatus   @default(HELD)

  // Asset Details
  brand           String
  model           String
  serialNumber    String?
  imei            String?
  color           String?
  condition       CollateralCondition
  batteryHealth   Int?
  screenCondition String?
  accessories     String[]
  hasCharger      Boolean            @default(false)
  hasBox          Boolean            @default(false)
  ageYears        Float?

  // Valuation
  marketValue     Float
  forcedSaleValue Float
  loanToValue     Float
  maxLoanAmount   Float

  // Storage Location
  shelfNumber     String?
  vaultPosition   String?
  lockerNumber    String?
  branchId        String?

  // Dates
  receivedAt      DateTime           @default(now())
  releasedAt      DateTime?
  auctionedAt     DateTime?

  // Release Info
  releasedBy      String?
  releasedTo      String?
  releaseNotes    String?
  releaseApprovedBy String?

  // Assessment
  assessedBy      String?
  assessedAt      DateTime?
  assessmentNotes String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  loans           Loan[]
  documents       Document[]
  custodyLogs     CustodyLog[]
  recoveryRecord  RecoveryRecord?
}

model CustodyLog {
  id            String     @id @default(uuid())
  collateralId  String
  collateral    Collateral @relation(fields: [collateralId], references: [id])
  action        String
  fromLocation  String?
  toLocation    String?
  notes         String?
  performedById String
  createdAt     DateTime   @default(now())
}

// ============================================================
// LOANS
// ============================================================

model Loan {
  id                  String             @id @default(uuid())
  loanNumber          String             @unique
  clientId            String
  client              Client             @relation(fields: [clientId], references: [id])
  collateralId        String?
  collateral          Collateral?        @relation(fields: [collateralId], references: [id])
  loanOfficerId       String
  loanOfficer         User               @relation("LoanOfficer", fields: [loanOfficerId], references: [id])
  approvedById        String?
  approvedBy          User?              @relation("LoanApprover", fields: [approvedById], references: [id])
  branchId            String?
  branch              Branch?            @relation(fields: [branchId], references: [id])

  status              LoanStatus         @default(DRAFT)
  loanType            String

  // Financials
  principal           Float
  interestRate        Float
  processingFee       Float              @default(0)
  processingFeeAmount Float              @default(0)
  insuranceFee        Float              @default(0)
  penaltyRate         Float              @default(0.05)

  // Calculated
  totalInterest       Float
  totalDue            Float
  totalPaid           Float              @default(0)
  outstandingBalance  Float
  penaltiesAccrued    Float              @default(0)

  // Schedule
  durationWeeks       Int?
  durationMonths      Int?
  repaymentFrequency  RepaymentFrequency @default(MONTHLY)
  installmentAmount   Float
  totalInstallments   Int

  // Dates
  applicationDate     DateTime           @default(now())
  approvalDate        DateTime?
  disbursementDate    DateTime?
  firstPaymentDate    DateTime?
  maturityDate        DateTime?
  closureDate         DateTime?

  // Notes
  purpose             String?
  rejectionReason     String?
  officerNotes        String?
  approvalNotes       String?

  // Risk
  parCategory         String?
  collectionStatus    CollectionStatus   @default(CURRENT)
  daysLate            Int                @default(0)
  lastPaymentDate     DateTime?

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  schedule            LoanSchedule[]
  payments            Payment[]
  documents           Document[]
  collectionLogs      CollectionLog[]
  recoveryRecord      RecoveryRecord?
}

model LoanSchedule {
  id              String        @id @default(uuid())
  loanId          String
  loan            Loan          @relation(fields: [loanId], references: [id])
  installmentNo   Int
  dueDate         DateTime
  principalDue    Float
  interestDue     Float
  totalDue        Float
  principalPaid   Float         @default(0)
  interestPaid    Float         @default(0)
  totalPaid       Float         @default(0)
  penalty         Float         @default(0)
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Payment {
  id              String        @id @default(uuid())
  paymentNumber   String        @unique
  loanId          String
  loan            Loan          @relation(fields: [loanId], references: [id])
  recordedById    String
  recordedBy      User          @relation("PaymentRecorder", fields: [recordedById], references: [id])
  amount          Float
  principalAmount Float
  interestAmount  Float
  penaltyAmount   Float         @default(0)
  method          String        @default("CASH")
  reference       String?
  notes           String?
  receiptUrl      String?
  paymentDate     DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ============================================================
// COLLECTIONS
// ============================================================

model CollectionLog {
  id              String   @id @default(uuid())
  loanId          String
  loan            Loan     @relation(fields: [loanId], references: [id])
  officerId       String
  officer         User     @relation(fields: [officerId], references: [id])
  type            String   // CALL, SMS, EMAIL, VISIT, PROMISE
  notes           String
  promiseAmount   Float?
  promiseDate     DateTime?
  outcome         String?
  nextAction      String?
  nextActionDate  DateTime?
  createdAt       DateTime @default(now())
}

// ============================================================
// RECOVERY
// ============================================================

model RecoveryRecord {
  id                String         @id @default(uuid())
  loanId            String         @unique
  loan              Loan           @relation(fields: [loanId], references: [id])
  collateralId      String?        @unique
  collateral        Collateral?    @relation(fields: [collateralId], references: [id])
  status            RecoveryStatus
  repossessionDate  DateTime?
  auctionDate       DateTime?
  auctionPrice      Float?
  recoveryAmount    Float          @default(0)
  auctioneer        String?
  notes             String?
  recoveredById     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id            String       @id @default(uuid())
  type          DocumentType
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  collateralId  String?
  collateral    Collateral?  @relation(fields: [collateralId], references: [id])
  loanId        String?
  loan          Loan?        @relation(fields: [loanId], references: [id])
  uploadedById  String
  notes         String?
  createdAt     DateTime     @default(now())
}

// ============================================================
// TASKS
// ============================================================

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  status        TaskStatus   @default(PENDING)
  priority      TaskPriority @default(MEDIUM)
  assigneeId    String
  assignee      User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById   String
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id])
  clientId      String?
  loanId        String?
  dueDate       DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ============================================================
// ACCOUNTING
// ============================================================

model Expense {
  id            String          @id @default(uuid())
  category      ExpenseCategory
  description   String
  amount        Float
  date          DateTime
  status        ExpenseStatus   @default(PENDING)
  receiptUrl    String?
  vendorName    String?
  submittedById String
  submittedBy   User            @relation(fields: [submittedById], references: [id])
  approvedById  String?
  approvedAt    DateTime?
  branchId      String?
  branch        Branch?         @relation(fields: [branchId], references: [id])
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// ============================================================
// INVESTORS
// ============================================================

model Investor {
  id              String         @id @default(uuid())
  investorNumber  String         @unique
  fullName        String
  phone           String
  email           String?
  nationalId      String?
  status          InvestorStatus @default(ACTIVE)
  totalInvested   Float          @default(0)
  currentBalance  Float          @default(0)
  returnRate      Float
  contractStart   DateTime
  contractEnd     DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  investments     Investment[]
  payouts         InvestorPayout[]
}

model Investment {
  id          String   @id @default(uuid())
  investorId  String
  investor    Investor @relation(fields: [investorId], references: [id])
  amount      Float
  date        DateTime
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
}

model InvestorPayout {
  id          String   @id @default(uuid())
  investorId  String
  investor    Investor @relation(fields: [investorId], references: [id])
  amount      Float
  date        DateTime
  type        String   // INTEREST, CAPITAL_RETURN, DIVIDEND
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id])
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  title       String
  message     String
  isRead      Boolean             @default(false)
  readAt      DateTime?
  loanId      String?
  clientId    String?
  sentAt      DateTime?
  error       String?
  createdAt   DateTime            @default(now())
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  subject     String
  bodyHtml    String
  bodyText    String?
  variables   String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// ANNOUNCEMENTS
// ============================================================

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  isPinned    Boolean  @default(false)
  expiresAt   DateTime?
  branchId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// INTERNAL WIKI
// ============================================================

model WikiPage {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  content     String
  category    String
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  isPublished Boolean    @default(true)
  viewCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id          String      @id @default(uuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  action      AuditAction
  entity      String
  entityId    String?
  oldValue    Json?
  newValue    Json?
  description String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
}

// ============================================================
// CAPITAL & PORTFOLIO
// ============================================================

model CapitalRecord {
  id              String   @id @default(uuid())
  date            DateTime @unique
  totalCapital    Float
  capitalLoaned   Float
  availableCapital Float
  utilizationPct  Float
  totalInvestors  Float
  ownCapital      Float
  createdAt       DateTime @default(now())
}

model PortfolioSnapshot {
  id              String   @id @default(uuid())
  date            DateTime @unique
  totalLoans      Int
  activeLoans     Int
  overdueLoans    Int
  defaultedLoans  Int
  paidLoans       Int
  totalDisbursed  Float
  totalOutstanding Float
  totalCollected  Float
  par1            Float
  par7            Float
  par30           Float
  par60           Float
  par90           Float
  defaultRate     Float
  recoveryRate    Float
  createdAt       DateTime @default(now())
}

// ============================================================
// PHASE 3 — LOAN PRODUCTS
// ============================================================

model LoanProduct {
  id              String     @id @default(uuid())
  name            String     @unique
  description     String?
  productType     String     // STUDENT, BUSINESS, PERSONAL, MARKET_TRADER
  minAmount       Float      @default(500)
  maxAmount       Float      @default(50000)
  processingFee   Float      @default(2)
  penaltyRate     Float      @default(5)
  isActive        Boolean    @default(true)
  createdById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  rates           LoanProductRate[]
}

model LoanProductRate {
  id            String      @id @default(uuid())
  productId     String
  product       LoanProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  weeks         Int
  interestRate  Float
  createdAt     DateTime    @default(now())
}

// ============================================================
// PHASE 3 — DOUBLE-ENTRY ACCOUNTING
// ============================================================

model ChartOfAccount {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  type        String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subType     String?
  balance     Float    @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  parent      ChartOfAccount?  @relation("AccountTree", fields: [parentId], references: [id])
  children    ChartOfAccount[] @relation("AccountTree")
  debitLines  JournalLine[]    @relation("DebitAccount")
  creditLines JournalLine[]    @relation("CreditAccount")
  createdAt   DateTime @default(now())
}

model JournalEntry {
  id          String        @id @default(uuid())
  reference   String        @unique
  date        DateTime
  description String
  totalAmount Float
  status      String        @default("POSTED")  // DRAFT, POSTED, REVERSED
  reversalOf  String?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       JournalLine[]
}

model JournalLine {
  id              String         @id @default(uuid())
  entryId         String
  entry           JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  debitAccountId  String?
  debitAccount    ChartOfAccount? @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId String?
  creditAccount   ChartOfAccount? @relation("CreditAccount", fields: [creditAccountId], references: [id])
  amount          Float
  description     String?
  createdAt       DateTime       @default(now())
}

// ============================================================
// PHASE 3 — CASHBOOK
// ============================================================

model CashbookEntry {
  id            String   @id @default(uuid())
  date          DateTime
  type          String   // RECEIPT, PAYMENT
  category      String
  description   String
  amount        Float
  balance       Float    @default(0)
  reference     String?
  branchId      String?
  loanId        String?
  recordedById  String?
  createdAt     DateTime @default(now())
}

// ============================================================
// PHASE 3 — BANK RECONCILIATION
// ============================================================

model BankReconciliation {
  id               String   @id @default(uuid())
  bankName         String
  accountNumber    String
  statementDate    DateTime
  statementBalance Float
  bookBalance      Float
  difference       Float
  status           String   @default("DRAFT")  // DRAFT, RECONCILED
  reconciledById   String?
  reconciledAt     DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ============================================================
// PHASE 3 — LOAN RESTRUCTURING & ROLLOVERS
// ============================================================

model LoanRestructure {
  id            String   @id @default(uuid())
  loanId        String
  type          String   // RESTRUCTURE, ROLLOVER
  oldPrincipal  Float
  newPrincipal  Float
  oldRate       Float
  newRate       Float
  oldMaturity   DateTime
  newMaturity   DateTime
  additionalFee Float    @default(0)
  reason        String
  approvedById  String
  approvedAt    DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
}

// ============================================================
// PHASE 3 — WRITE-OFFS & PROVISIONING
// ============================================================

model WriteOff {
  id            String   @id @default(uuid())
  loanId        String   @unique
  amount        Float
  reason        String
  approvedById  String
  approvedAt    DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
}

model BadDebtProvision {
  id              String   @id @default(uuid())
  periodDate      DateTime @unique
  par30Amount     Float
  par60Amount     Float
  par90Amount     Float
  defaultAmount   Float
  rate30          Float    @default(0.25)
  rate60          Float    @default(0.50)
  rate90          Float    @default(0.75)
  rateDefault     Float    @default(1.0)
  provision30     Float
  provision60     Float
  provision90     Float
  provisionDefault Float
  totalProvision  Float
  createdById     String?
  createdAt       DateTime @default(now())
}

// ============================================================
// PHASE 3 — PENALTIES
// ============================================================

model PenaltyRecord {
  id          String   @id @default(uuid())
  loanId      String
  amount      Float
  reason      String
  daysLate    Int
  waived      Boolean  @default(false)
  waivedById  String?
  waivedAt    DateTime?
  waivedReason String?
  createdAt   DateTime @default(now())
}

// ============================================================
// PHASE 3 — COLLATERAL AUCTIONS
// ============================================================

model CollateralAuction {
  id              String   @id @default(uuid())
  collateralId    String   @unique
  loanId          String
  reservePrice    Float
  listingDate     DateTime
  auctionDate     DateTime?
  soldPrice       Float?
  buyerName       String?
  buyerContact    String?
  status          String   @default("LISTED")  // LISTED, SOLD, FAILED, CANCELLED
  notes           String?
  managedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// PHASE 3 — ONLINE APPLICATIONS (CLIENT PORTAL)
// ============================================================

model OnlineApplication {
  id              String   @id @default(uuid())
  applicationRef  String   @unique
  status          String   @default("DRAFT")
  // DRAFT, SUBMITTED, UNDER_REVIEW, INFO_REQUIRED, APPROVED, REJECTED, DISBURSED
  firstName       String
  lastName        String
  email           String
  phone           String
  nrcNumber       String
  clientType      String
  loanAmount      Float
  loanPurpose     String
  collateralType  String
  collateralBrand String?
  collateralModel String?
  // Employment/Business
  employer        String?
  monthlySalary   Float?
  businessName    String?
  monthlyRevenue  Float?
  // References
  reference1Name  String?
  reference1Phone String?
  reference2Name  String?
  reference2Phone String?
  existingLoans   Boolean  @default(false)
  previousDefaults Boolean @default(false)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  reviewNotes     String?
  ipAddress       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  photos          ApplicationPhoto[]
}

model ApplicationPhoto {
  id            String            @id @default(uuid())
  applicationId String
  application   OnlineApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  photoType     String            // FRONT, BACK, SIDE, SERIAL, IMEI, NRC_FRONT, NRC_BACK
  url           String
  fileName      String
  createdAt     DateTime          @default(now())
}

// ============================================================
// PHASE 3 — KYC VERIFICATION
// ============================================================

model KYCRecord {
  id                  String   @id @default(uuid())
  clientId            String   @unique
  nrcVerified         Boolean  @default(false)
  faceMatchVerified   Boolean  @default(false)
  addressVerified     Boolean  @default(false)
  employmentVerified  Boolean  @default(false)
  phoneVerified       Boolean  @default(false)
  status              String   @default("PENDING")  // PENDING, PARTIAL, VERIFIED, FAILED
  verifiedById        String?
  verifiedAt          DateTime?
  rejectionReason     String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================================
// PHASE 3 — CLIENT TIMELINE
// ============================================================

model ClientEvent {
  id          String   @id @default(uuid())
  clientId    String
  type        String   // APPLICATION, APPROVAL, CALL, PAYMENT, REMINDER, COLLECTION, NOTE, KYC, BLACKLIST
  title       String
  description String?
  amount      Float?
  userId      String?
  loanId      String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

// ============================================================
// PHASE 3 — PROMISES TO PAY
// ============================================================

model PromiseToPay {
  id            String   @id @default(uuid())
  loanId        String
  clientId      String
  officerId     String
  amount        Float
  promisedDate  DateTime
  fulfilled     Boolean  @default(false)
  fulfilledAt   DateTime?
  broken        Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
}

// ============================================================
// PHASE 3 — DOCUMENT EXPIRY
// ============================================================

model DocumentExpiry {
  id            String   @id @default(uuid())
  clientId      String
  documentType  String
  documentRef   String?
  expiryDate    DateTime
  notifiedAt    DateTime?
  renewedAt     DateTime?
  status        String   @default("ACTIVE")  // ACTIVE, EXPIRING_SOON, EXPIRED, RENEWED
  notes         String?
  createdAt     DateTime @default(now())
}

// ============================================================
// PHASE 3 — BUDGETING
// ============================================================

model Budget {
  id          String   @id @default(uuid())
  month       Int
  year        Int
  category    ExpenseCategory
  budgeted    Float
  actual      Float    @default(0)
  variance    Float    @default(0)
  branchId    String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([month, year, category])
}

// ============================================================
// PHASE 3 — ASSET REGISTER
// ============================================================

model AssetRegister {
  id              String   @id @default(uuid())
  assetCode       String   @unique
  name            String
  category        String   // FURNITURE, EQUIPMENT, VEHICLE, COMPUTER, OTHER
  purchaseDate    DateTime
  purchaseValue   Float
  currentValue    Float
  annualDepreciation Float @default(0)
  condition       String   @default("GOOD")
  location        String?
  assignedToId    String?
  branchId        String?
  disposedAt      DateTime?
  disposalReason  String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// PHASE 3 — STAFF LEAVE
// ============================================================

model LeaveRequest {
  id            String   @id @default(uuid())
  userId        String
  leaveType     String   // ANNUAL, SICK, MATERNITY, PATERNITY, UNPAID, COMPASSIONATE
  startDate     DateTime
  endDate       DateTime
  days          Int
  reason        String
  status        String   @default("PENDING")  // PENDING, APPROVED, REJECTED
  approvedById  String?
  approvedAt    DateTime?
  rejectedReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// PHASE 3 — MEETING MINUTES
// ============================================================

model MeetingMinute {
  id            String   @id @default(uuid())
  title         String
  meetingDate   DateTime
  location      String?
  attendees     String[]
  agenda        String
  minutes       String
  actionItems   Json?    // Array of {item, assignee, dueDate, status}
  recordedById  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// PHASE 3 — COMPLIANCE
// ============================================================

model ComplianceRecord {
  id            String   @id @default(uuid())
  type          String   // LICENSE, REGULATION, TAX, AUDIT, REPORTING
  title         String
  description   String?
  authority     String?
  dueDate       DateTime?
  completedAt   DateTime?
  status        String   @default("PENDING")  // PENDING, IN_PROGRESS, COMPLIANT, NON_COMPLIANT
  assignedToId  String?
  notes         String?
  attachmentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// PHASE 3 — INTERNAL PROCUREMENT
// ============================================================

model ProcurementRequest {
  id              String   @id @default(uuid())
  requestNumber   String   @unique
  title           String
  description     String
  amount          Float
  vendor          String?
  category        String   // EQUIPMENT, STATIONERY, SERVICES, MAINTENANCE, OTHER
  requestedById   String
  status          String   @default("PENDING")  // PENDING, APPROVED, REJECTED, ORDERED, RECEIVED
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  receiptUrl      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// PHASE 3 — EMAIL LOGS
// ============================================================

model EmailLog {
  id          String   @id @default(uuid())
  to          String
  toName      String?
  subject     String
  template    String?
  body        String?
  status      String   @default("SENT")  // SENT, FAILED, BOUNCED
  error       String?
  loanId      String?
  clientId    String?
  triggeredBy String?  // SYSTEM, USER_ID
  sentAt      DateTime @default(now())
}

// ============================================================
// PHASE 3 — IMPORT LOGS
// ============================================================

model ImportLog {
  id            String   @id @default(uuid())
  type          String   // CLIENTS, LOANS, PAYMENTS
  fileName      String
  totalRows     Int
  successRows   Int      @default(0)
  failedRows    Int      @default(0)
  status        String   @default("PROCESSING")  // PROCESSING, COMPLETED, FAILED
  errors        Json?
  importedById  String?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
}

// ============================================================
// CLIENT PORTAL — Self-service account for borrowers
// ============================================================

enum KycStatus {
  NOT_STARTED
  SUBMITTED
  IN_REVIEW
  VERIFIED
  REJECTED
}

enum PortalAccountStatus {
  ACTIVE
  PENDING_KYC
  SUSPENDED
  BLACKLISTED
}

model ClientPortalAccount {
  id                String              @id @default(uuid())
  clientNumber      String              @unique
  email             String              @unique
  passwordHash      String
  firstName         String
  lastName          String
  phone             String
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  occupation        String?
  employer          String?
  monthlyIncome     Float?
  nrcNumber         String?
  kycStatus         KycStatus           @default(NOT_STARTED)
  kycSubmittedAt    DateTime?
  kycVerifiedAt     DateTime?
  kycRejectedReason String?
  status            PortalAccountStatus @default(PENDING_KYC)
  // Link to internal Client record (set after KYC verification)
  linkedClientId    String?             @unique
  // Auth
  failedLoginCount  Int                 @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  emailVerified     Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  portalLoans       PortalLoanApplication[]
  portalRefreshTokens PortalRefreshToken[]
  kycDocuments      KycDocument[]
  collateralPhotos  PortalCollateralPhoto[]
  notifications     ClientNotification[]

  @@index([email])
  @@index([clientNumber])
}

model PortalRefreshToken {
  id          String              @id @default(uuid())
  token       String              @unique
  accountId   String
  account     ClientPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime            @default(now())
}

model KycDocument {
  id          String              @id @default(uuid())
  accountId   String
  account     ClientPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  docType     String              // NRC_FRONT, NRC_BACK, SELFIE, PROOF_OF_ADDRESS
  fileUrl     String
  fileName    String
  mimeType    String
  uploadedAt  DateTime            @default(now())
}

model PortalLoanApplication {
  id              String              @id @default(uuid())
  reference       String              @unique
  accountId       String
  account         ClientPortalAccount @relation(fields: [accountId], references: [id])
  productType     String              // SALARY_ADVANCE, BUSINESS, MICRO, ASSET_FINANCE
  amountRequested Float
  termMonths      Int
  purpose         String
  description     String?
  occupation      String?
  employer        String?
  employerPhone   String?
  monthlyIncome   Float?
  payDate         String?
  collateralType  String?
  collateralDesc  String?
  collateralValue Float?
  ref1Name        String?
  ref1Phone       String?
  ref1Relation    String?
  ref2Name        String?
  ref2Phone       String?
  ref2Relation    String?
  status          String              @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED, DISBURSED
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectedReason  String?
  // Linked to actual Loan record after approval
  linkedLoanId    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model PortalCollateralPhoto {
  id          String              @id @default(uuid())
  accountId   String
  account     ClientPortalAccount @relation(fields: [accountId], references: [id])
  photoType   String              // FRONT, BACK, SERIAL, RECEIPT
  fileUrl     String
  fileName    String
  description String?
  linkedLoan  String?
  uploadedAt  DateTime            @default(now())
}

model ClientNotification {
  id          String              @id @default(uuid())
  accountId   String
  account     ClientPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject     String
  body        String              @db.Text
  category    String              // LOAN, PAYMENT, KYC, ACCOUNT, COLLECTION, GENERAL
  isRead      Boolean             @default(false)
  sentViaEmail Boolean            @default(false)
  createdAt   DateTime            @default(now())
}
